# Server Configuration
PORT=8888
NODE_ENV=development

# Trust X-Forwarded-* from reverse proxy (Easypanel/Traefik/Nginx). Use 1, true, or yes.
# TRUST_PROXY=1

# OpenRouter AI Configuration
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat

# API Keys
API_KEY_REGISTER=xx
API_KEY_MANAGE=xx
ROUTE_PERMISSIONS_FILE=./route-permissions.json

# Rate limiting (optional; omit to use defaults: general 2500/15m, auth 250/15m, AI 75/min)
# General
RATE_LIMIT_GENERAL_MAX=10000
RATE_LIMIT_GENERAL_WINDOW_MS=60000

# Auth
RATE_LIMIT_AUTH_MAX=1200
RATE_LIMIT_AUTH_WINDOW_MS=60000

# AI ← Nới rộng vì pay-per-use
RATE_LIMIT_AI_MAX=1000          # có thể lên 1500-2000 nếu infrastructure mạnh
RATE_LIMIT_AI_WINDOW_MS=60000